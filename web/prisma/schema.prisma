generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Expense {
  id              Int      @id @default(autoincrement())
  title           String
  amount          Int
  category        String
  type            String   // 'EXPENSE' or 'INCOME'
  description     String?
  transactionDate String
  createdAt       DateTime @default(now())
}
